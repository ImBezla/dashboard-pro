# syntax=docker/dockerfile:1
# Next.js 14 (standalone) — setzt Build-Args für öffentliche URLs
FROM node:20-bookworm-slim AS deps
WORKDIR /app
RUN apt-get update && apt-get install -y openssl ca-certificates && rm -rf /var/lib/apt/lists/*
COPY package.json package-lock.json turbo.json ./
COPY apps/api/package.json apps/api/
COPY apps/web/package.json apps/web/
COPY packages/types/package.json packages/types/
RUN npm ci

FROM deps AS build
ARG NEXT_PUBLIC_API_URL=http://localhost:3002
ARG NEXT_PUBLIC_SITE_URL=http://localhost:3000
ENV NEXT_TELEMETRY_DISABLED=1
ENV NEXT_PUBLIC_API_URL=$NEXT_PUBLIC_API_URL
ENV NEXT_PUBLIC_SITE_URL=$NEXT_PUBLIC_SITE_URL
# Im Image-Build kein ESLint (spart RAM/CPU); Qualität: `npm run lint` in CI.
ENV SKIP_NEXT_LINT=1
# Weniger Parallelität + kein TS-Check im Image (siehe next.config.js); CI führt vollen Build.
ENV DOCKER_LOW_MEM=1
# Heap-Limit: auf 2 GB RAM VPS lieber zusätzlich 1–2 GB Swap anlegen.
ENV NODE_OPTIONS="--max-old-space-size=3072"
COPY apps/web ./apps/web
COPY packages ./packages
RUN npm run build --workspace=@dashboardpro/web -- --no-lint

FROM node:20-bookworm-slim AS runner
WORKDIR /app
RUN addgroup --system --gid 1001 nodejs \
  && adduser --system --uid 1001 --ingroup nodejs nextjs
ENV NODE_ENV=production
ENV PORT=3000
ENV HOSTNAME=0.0.0.0
COPY --from=build --chown=nextjs:nodejs /app/apps/web/.next/standalone ./
COPY --from=build --chown=nextjs:nodejs /app/apps/web/.next/static ./apps/web/.next/static
COPY --from=build --chown=nextjs:nodejs /app/apps/web/public ./apps/web/public
USER nextjs
EXPOSE 3000
CMD ["node", "apps/web/server.js"]
