# --- Nur für lokale Entwicklung (npm run dev / npx prisma im Ordner apps/api) ---
#
# Ohne funktionierendes SMTP: Registrierung bricht beim Versand der Bestätigungsmail ab.
# Schnellstart (nur lokal): Zeile auskommentieren, API neu starten:
# SKIP_EMAIL_VERIFICATION=true
# VPS / Docker: die API bekommt Variablen aus Repo-Root .env.deploy (docker compose --env-file …).
# apps/api/.env wird im Produktions-Image NICHT eingebunden — dort zählt nur .env.deploy.
#
# Datenbank: PostgreSQL (Prisma). Lokal: repo-root docker-compose.yml → Postgres, dann z. B.:
DATABASE_URL="postgresql://dashboardpro:dashboardpro@localhost:5432/dashboardpro?schema=public"
# Produktion: Supabase (Session Pooler empfohlen) — siehe docs/SUPABASE.md

# Muss mit apps/web JWT_SECRET identisch sein (sonst: Login ok, dann sofort wieder /login).
JWT_SECRET=your-secret-key-change-in-production

# Basis-URL der Next.js-App (E-Mail-Links, CORS)
FRONTEND_URL=http://localhost:8000

# E-Mail: Variante 0 – Resend (HTTPS-API, empfohlen wenn Gmail-SMTP 535 / BadCredentials)
# https://resend.com — API-Key erzeugen, Domain verifizieren, dann z. B.:
# RESEND_API_KEY=re_xxxxxxxx
# RESEND_FROM="DashboardPro <notify@ihre-verifizierte-domain.de>"
# Ohne RESEND_FROM nutzt die API onboarding@resend.dev — dann sind nur Test-Mails an die
# bei Resend hinterlegte Konto-E-Mail erlaubt (Registrierung mit anderer Adresse schlägt fehl).
# Für echte Nutzer: Domain verifizieren + RESEND_FROM auf diese Domain setzen.
# Wenn RESEND_API_KEY gesetzt ist, wird er vor SMTP/Gmail genutzt.
# Wenn Resend-Sandbox nur eure Konto-Mail erlaubt: allgemeine Mails versuchen SMTP nach Resend-Fehler;
# Bestätigungs- & Passwort-Reset-Mails gehen bei onboarding@… + Gmail direkt über SMTP (zuverlässige Verifizierung).
# Nur SMTP, kein Resend: EMAIL_PROVIDER=smtp

# E-Mail: Variante A – beliebiges SMTP
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=apikey
# SMTP_PASS=
# SMTP_FROM="DashboardPro <noreply@example.com>"

# E-Mail: Variante B – Gmail (App-Passwort), ohne SMTP_HOST
# GMAIL_APP_PASSWORD=… (empfohlen). SMTP_PASS= nur nutzen, wenn ein nicht-leerer Wert gesetzt ist (leeres SMTP_PASS= würde sonst das App-Passwort ignorieren).
# SMTP_USER=ihre.adresse@gmail.com
# GMAIL_APP_PASSWORD=xxxxxxxxxxxxxxxx
# (Alternative: dasselbe App-Passwort in SMTP_PASS=, wenn kein SMTP_HOST gesetzt ist)

# Nur Entwicklung: Registrierung sofort mit JWT, ohne Bestätigungs-Mail
# SKIP_EMAIL_VERIFICATION=true

PORT=3002

# Newsletter (Landing): Double-Opt-in-Mail an Nutzer; nach Bestätigung Benachrichtigung an:
# NEWSLETTER_ADMIN_EMAIL=deine-adresse@gmail.com

# --- Produktion / Go-Live (Kurz-Checkliste) ---
# - JWT_SECRET: starkes, zufälliges Geheimnis (nicht "change-me")
# - FRONTEND_URL: öffentliche HTTPS-URL der Web-App (E-Mail-Links, CORS)
# - SKIP_EMAIL_VERIFICATION: nicht setzen oder false – Verifizierung aktiv lassen
# - SMTP_* bzw. Gmail: gültige Zugangsdaten, Absender-Adresse verifiziert
# - Datenbank: DATABASE_URL auf persistentes Ziel (nicht lokale Dev-Datei)
# - Throttling: Standard 120/min global; sensible Endpunkte enger – bei Bedarf anpassen
# - Security: API nutzt Helmet (HTTP-Header); Reverse-Proxy TLS terminieren
# - DSGVO: GET /users/me/data-export (throttled) – personenbezogene Daten als JSON
# - Postgres optional: Repo-Root `docker compose up -d`, dann DATABASE_URL + schema provider anpassen
