# API-Basis-URL (Browser).
# - Lokal: http://localhost:3002
# - Produktion: https://api.example.com
# - Single-Domain via Reverse-Proxy: /api
NEXT_PUBLIC_API_URL=http://localhost:3002

# Öffentliche URL der Web-App (Canonical, Open Graph, Sitemap, JSON-LD). Beta/Prod: https://…
NEXT_PUBLIC_SITE_URL=http://localhost:8000

# Optional: Hostname in der Landing-Footer-Zeile (Copyright). Ohne Eintrag wird bei localhost
# in NEXT_PUBLIC_SITE_URL z. B. dashboardpro.de angezeigt statt „localhost“.
# NEXT_PUBLIC_FOOTER_SITE_LABEL=www.dashboardpro.de

# Muss mit apps/api JWT_SECRET identisch sein (Middleware + Session-Cookie).
JWT_SECRET=your-secret-key-change-in-production

# Gleiche Liste wie in apps/api — Middleware erlaubt /admin nur für diese E-Mails (oder JWT globalRole ADMIN).
# PLATFORM_ADMIN_EMAILS=du@example.com

# --- Optional: Suchmaschinen-Verifikation ---
# NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=
# NEXT_PUBLIC_BING_SITE_VERIFICATION=
# NEXT_PUBLIC_YANDEX_VERIFICATION=

# --- Optional: Twitter / X Cards ---
# NEXT_PUBLIC_TWITTER_SITE=@deinfirma
# NEXT_PUBLIC_TWITTER_CREATOR=@deinfirma

# Optional: Facebook / Meta „fb:app_id“ (Link-Vorschau, App-Insights)
# NEXT_PUBLIC_FACEBOOK_APP_ID=

# Optional: JSON-LD sameAs — kommagetrennte Profil-URLs (https://…)
# NEXT_PUBLIC_ORG_SAME_AS=https://www.linkedin.com/company/…,https://x.com/…

# --- Optional: GEO (Meta-Tags) ---
# NEXT_PUBLIC_GEO_REGION=DE
# NEXT_PUBLIC_GEO_PLACENAME=Geisenfeld
# NEXT_PUBLIC_GEO_POSITION=48.684;11.611
