# Kopie nach .env.deploy und Werte setzen (nicht committen).
# Verwendung: docker compose --env-file .env.deploy -f docker-compose.deploy.yml up -d --build

# --- Pflicht ---
JWT_SECRET=generiere-mit-openssl-rand-base64-32
FRONTEND_URL=https://app.deine-domain.de
NEXT_PUBLIC_SITE_URL=https://app.deine-domain.de
# Öffentliche API-URL (vom Browser aus erreichbar; Subdomain üblich)
NEXT_PUBLIC_API_URL=https://api.deine-domain.de
#
# Beispiel Hostinger / dashboardpro.de:
# FRONTEND_URL=https://dashboardpro.de
# NEXT_PUBLIC_SITE_URL=https://dashboardpro.de
# NEXT_PUBLIC_API_URL=https://api.dashboardpro.de
#
# Alternative Single-Domain (API unter /api via nginx):
# NEXT_PUBLIC_API_URL=/api
#
# CORS: FRONTEND_URL + www/Apex-Variante werden in der API automatisch erlaubt.
# ADDITIONAL_CORS_ORIGINS nur mit vertrauenswürdigen https://-Origins (kommagetrennt), sonst Session-Hijack-Risiko.
# ADDITIONAL_CORS_ORIGINS=https://staging.example.com
#
# Produktion: SKIP_EMAIL_VERIFICATION nicht setzen (oder false). true = jeder kann ohne E-Mail-Bestätigung
# registrieren — nur in abgeschlossenen Testumgebungen.
# SKIP_EMAIL_VERIFICATION=true

# --- Ports auf dem Host (optional) ---
# docker-compose.deploy.yml bindet standardmäßig an 127.0.0.1 (sicher mit nginx auf demselben VPS).
# API_PUBLISH_PORT=3002
# WEB_PUBLISH_PORT=3000
# Nur nötig, wenn du ohne Reverse-Proxy direkt an Docker willst (nicht empfohlen öffentlich):
# API_PUBLISH_BIND=0.0.0.0
# WEB_PUBLISH_BIND=0.0.0.0

# --- SQLite (Standard im Compose) ---
DATABASE_URL=file:/data/prod.db

# --- E-Mail ---
# Ohne SMTP schlägt /auth/register fehl (400), solange SKIP_EMAIL_VERIFICATION nicht true ist.
# Für VPS ohne Mailserver vorübergehend: SKIP_EMAIL_VERIFICATION=true (siehe oben).
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=DashboardPro <noreply@example.com>

# --- Twilio SMS (optional) ---
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_FROM_NUMBER=+15551234567

# --- Web: SEO / Verifikation (optional, in Web-Image .env bzw. Compose übergeben) ---
# NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=
# NEXT_PUBLIC_BING_SITE_VERIFICATION=
# NEXT_PUBLIC_YANDEX_VERIFICATION=
